# ---------------------------------------------------------
# Your Student Companion — Environment Variables
# ---------------------------------------------------------
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file matching .env.* to git.
# ---------------------------------------------------------

# ── Clerk Authentication ──────────────────────────────────
# Get your publishable key from https://dashboard.clerk.com
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── Supabase ──────────────────────────────────────────────
# Project URL and anon key from https://supabase.com/dashboard
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGci...REPLACE_ME

# ── Backend API ───────────────────────────────────────────
# URL of the FastAPI backend (defaults to localhost:8000)
REACT_APP_API_BASE_URL=http://localhost:8000

# ── Sentry (frontend observability) ────────────────────────
# DSN from Sentry → Project Settings → Client Keys (DSN).
# Safe to expose in client bundle — Sentry's intended design.
# When missing, the SDK no-ops cleanly (errors won't be reported).
REACT_APP_SENTRY_DSN=https://REPLACE_ME@oXXXXX.ingest.us.sentry.io/REPLACE_ME

# Used by @sentry/webpack-plugin at production build time to upload
# source maps so stack traces show real code instead of minified output.
# Production-only; build skips upload silently if any are missing.
SENTRY_ORG_SLUG=your-org-slug
SENTRY_PROJECT_SLUG=javascript-react
# AUTH TOKEN IS A SECRET — keep in .env.local + Vercel env, never in git.
# Create at https://sentry.io/settings/account/api/auth-tokens/
# Scopes required: project:releases, org:read
SENTRY_AUTH_TOKEN=sntrys_REPLACE_ME

# ── Optional: Health / Dev Plugins ────────────────────────
# Set to "true" to enable the webpack health-check plugin
ENABLE_HEALTH_CHECK=false

# ── PostHog (product analytics) ────────────────────────────
# Project API key from https://us.posthog.com → Project Settings.
# When missing, analytics no-ops entirely (same contract as Sentry).
# Autocapture and session recording are disabled in code; only the
# explicit funnel events in src/lib/analytics.js are sent.
REACT_APP_POSTHOG_KEY=phc_REPLACE_ME
REACT_APP_POSTHOG_HOST=https://us.i.posthog.com
